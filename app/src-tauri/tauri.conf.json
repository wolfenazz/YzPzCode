{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YzPzCode",
  "version": "1.5.5",
  "identifier": "com.yzpzcode.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:8745",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "YzPzCode",
        "width": 1200,
        "height": 800,
        "minWidth": 1020,
        "minHeight": 810,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENDQzQwNDQ0NkI0NDk2MTMKUldRVGxrUnJSQVRFek9ER0lpQlQ5UG1RVTdxaWNHQlQyNDFxMmdkNGpKTVFPOFE3b2NrWXlGcWwK",
      "endpoints": [
        "https://github.com/wolfenazz/YzPzCode/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}